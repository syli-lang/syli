--- test_single_block: input
module Test :
functions:
public fn test_single() -> i64:
  entry: bb10

  bb10:
    %x:Obj = object_create{size=8:i64 record{fields=1 tag=0 [i64]}}
    %y:Obj = object_create{size=8:i64 record{fields=1 tag=0 [i64]}}
    rc_check_release(%x:Obj)
    rc_check_release(%y:Obj)
    return
end

end
--- test_single_block: live_map
  stmt 1: live_before={}  live_after={x}
  stmt 2: live_before={x}  live_after={x, y}
  stmt 3: live_before={x, y}  live_after={y}
  stmt 4: live_before={y}  live_after={}

--- test_two_blocks: input
module Test :
functions:
