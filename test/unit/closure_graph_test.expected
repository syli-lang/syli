--- test_cast_dispatch_possibilities
module Test :
functions:
public fn test() -> void:
  entry: bb59

  bb59:
    %c:(i64, i64 -> i64) = #make_closure {Test.add} () ()
    %c1:(f64, i64 -> i64) = cast(%c:(i64, i64 -> i64) as (f64, i64 -> i64))
    %r1:i64 = #call_apply {%c1:(f64, i64 -> i64)}  (1:f64, 2:i64)
    %c2:(i64, i64 -> i64) = cast(%c:(i64, i64 -> i64) as (i64, i64 -> i64))
    %r2:i64 = #call_apply {%c2:(i64, i64 -> i64)}  (3:i64, 4:i64)
    return
end

end
