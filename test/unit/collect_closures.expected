--- test_empty_program_has_no_lambdas
module Test

--- test_empty_program_has_no_lambdas: result
core_closure_analysis {
  closure_infos =
  (no lambdas registered)
}

--- test_toplevel_lambda_registers_decl_id
module Test
let f = fun () : unit ->
    () : unit


--- test_toplevel_lambda_registers_decl_id: result
core_closure_analysis {
  closure_infos =
  { id=2  free_vars={}  lambda(params=[]) }
}

