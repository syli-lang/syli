--- test_build_cfg_chain
module Test :
functions:
public fn __test() -> void:
  entry: bb1

  bb1:

    goto bb2

  bb2:

    return
end

end
  succ[1] = [2]
  pred[2] = [1]

--- test_build_cfg_switch
module Test :
functions:
public fn __test() -> void:
  entry: bb1

  bb1:

    switch %__dummy:i64 [0: bb2, 1: bb3 default: bb4]

  bb2:

    return

  bb3:

    return

  bb4:

    return
end

end
  succ[1] = [4, 2, 3]
  pred[2] = [1]
  pred[3] = [1]
  pred[4] = [1]

